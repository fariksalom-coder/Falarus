{
  "name": "react-example",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "cross-env NODE_OPTIONS=--disable-warning=DEP0169 tsx server.ts",
    "dev:prod": "cross-env VITE_API_URL=https://falarus.uz NODE_OPTIONS=--disable-warning=DEP0169 tsx server.ts",
    "build": "vite build",
    "start": "cross-env NODE_OPTIONS=--disable-warning=DEP0169 tsx server.ts",
    "preview": "vite preview",
    "clean": "rm -rf dist",
    "lint": "tsc --noEmit",
    "test": "node --import tsx --test tests/**/*.test.ts",
    "check:env": "node scripts/check-env.mjs",
    "db:push": "node scripts/db-push.mjs",
    "db:verify": "node scripts/db-verify.mjs",
    "seed:vocabulary": "tsx server/scripts/seedVocabulary.ts",
    "seed:admin": "tsx server/scripts/seedAdmin.ts",
    "import:patent": "python3 scripts/import_patent_exam.py",
    "upload:course-media": "tsx scripts/upload-course-media.ts",
    "compress:course-mp4": "node scripts/compress-mp4-for-supabase-free.mjs",
    "test:catchall": "node --import tsx scripts/smoke-catchall-local.ts",
    "test:smoke": "node scripts/smoke-api.mjs",
    "test:smoke:full": "cross-env SMOKE_INCLUDE_LESSONS=1 node scripts/smoke-api.mjs",
    "verify": "npm run lint && npm run test && npm run build"
  },
  "dependencies": {
    "@google/genai": "^1.29.0",
    "@supabase/supabase-js": "^2.47.0",
    "@tailwindcss/vite": "^4.1.14",
    "@vitejs/plugin-react": "^5.0.4",
    "bcryptjs": "^3.0.3",
    "busboy": "^1.6.0",
    "clsx": "^2.1.1",
    "dotenv": "^17.2.3",
    "express": "^4.21.2",
    "ioredis": "^5.4.1",
    "jsonwebtoken": "^9.0.3",
    "lucide-react": "^0.546.0",
    "motion": "^12.23.24",
    "multer": "^2.1.1",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-router-dom": "^7.13.1",
    "tailwind-merge": "^3.5.0",
    "vite": "^6.2.0",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/multer": "^2.1.0",
    "@types/node": "^22.14.0",
    "@types/react-router-dom": "^5.3.3",
    "@vercel/node": "^3.2.0",
    "autoprefixer": "^10.4.21",
    "cross-env": "^10.1.0",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "vite": "^6.2.0"
  }
}
