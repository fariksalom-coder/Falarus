# Supabase (required for API)
SUPABASE_URL="https://YOUR_PROJECT_REF.supabase.co"
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"

# Optional: for Supabase CLI (npm run db:push). Either:
# SUPABASE_DB_PASSWORD=...   (and optionally SUPABASE_POOLER_REGION=eu-west-1 etc.)
# or paste the full URI from Dashboard → Database → Connection string:
# SUPABASE_DB_URL="postgresql://postgres.XXXX:PASSWORD@aws-0-REGION.pooler.supabase.com:6543/postgres"

# Optional: custom JWT secret for app auth (defaults to a dev value)
JWT_SECRET="your-secret"

# App timezone for statistics aggregation and daily limits.
APP_TIMEZONE="Asia/Tashkent"

# Admin panel: create first admin with npm run seed:admin (uses same JWT_SECRET)
# ADMIN_EMAIL=admin@falarus.uz
# ADMIN_PASSWORD=your-secure-password

# GEMINI_API_KEY: Optional, for Gemini AI API calls.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# VITE_API_URL: Backend API URL. Leave empty when running locally (npm run dev) = local backend + local DB.
# On Vercel: set to your backend URL (e.g. https://falarus.uz).
#
# Same data as online (one account everywhere):
#   Run:  npm run dev:prod
#   This uses https://falarus.uz as API, so localhost shows the same progress as falarus.uz for the same login.
VITE_API_URL=""

# Optional: public base URL for course media (audio/video/images) when files are NOT in Git — e.g. Supabase Storage
# or Cloudflare R2 / any CDN with the same paths as `public/courses/` (URLs stay `/courses/...` in code).
# Example Supabase: VITE_COURSE_MEDIA_BASE_URL="https://YOUR_PROJECT.supabase.co/storage/v1/object/public/course-assets"
# Example R2:        VITE_COURSE_MEDIA_BASE_URL="https://pub-xxxxx.r2.dev"  (must mirror /courses/... layout)
# VITE_COURSE_MEDIA_BASE_URL=""
#
# Production build (Vercel): committed `.env.production` is loaded by `vite build` (see also Vercel env overrides).
#
# Upload to Supabase: npm run upload:course-media (needs SUPABASE_SERVICE_ROLE_KEY). Free plan: max 50 MB per file —
# run npm run compress:course-mp4 first if you have larger .mp4. Pro plan: raise Storage global file size limit in Dashboard.
# Optional: COURSE_MEDIA_BUCKET=course-assets

# Optional: Redis URL for vocabulary progress cache (5 min TTL). If not set, cache is skipped.
# REDIS_URL="redis://localhost:6379"

# Optional: base URL for referral links (default: https://www.falarus.uz)
# REFERRAL_BASE_URL="https://www.falarus.uz"

# Optional: smoke-test settings for deployed API.
# SMOKE_BASE_URL="https://your-project.vercel.app"
# SMOKE_EMAIL="student@example.com"
# SMOKE_PASSWORD="secret"
# or:
# SMOKE_BEARER_TOKEN="..."
