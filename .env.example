# Supabase (required for API)
SUPABASE_URL="https://YOUR_PROJECT_REF.supabase.co"
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"

# Optional: custom JWT secret for app auth (defaults to a dev value)
JWT_SECRET="your-secret"

# GEMINI_API_KEY: Optional, for Gemini AI API calls.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# VITE_API_URL: Backend API URL. Leave empty when running locally (npm run dev).
# On Vercel: set to your backend URL (e.g. https://your-app.railway.app or https://your-app.onrender.com).
VITE_API_URL=""
